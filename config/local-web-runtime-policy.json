{
  "schemaVersion": 1,
  "runtimeId": "haven42.local-web",
  "implementationStatus": "text-tools-admitted",
  "bind": {
    "allowedAddresses": ["127.0.0.1"],
    "defaultPort": 4242,
    "remoteBindAllowed": false
  },
  "browser": {
    "bundledAssetsOnly": true,
    "remoteAssetsAllowed": false,
    "telemetryAllowed": false,
    "crossOriginRequestsAllowed": false,
    "hostHeaderValidationRequired": true,
    "csrfTokenRequiredForEffects": true,
    "contentSecurityPolicyRequired": true
  },
  "providerConnections": {
    "configuredInMemoryOnly": true,
    "allowedTrustScopes": ["loopback", "trusted-lan"],
    "trustScopeSelection": "server-inferred-from-ip-literal",
    "ipLiteralRequired": true,
    "credentialsInUrlAllowed": false,
    "redirectsAllowed": false,
    "modelDiscoveryRequiredBeforeUse": true
  },
  "text": {
    "capabilityIds": ["general.chat", "content.write", "content.summarize"],
    "providerId": "ollama.local-text",
    "repositoryAccess": false,
    "fileWrites": false,
    "messagePersistence": false,
    "endpointPersistence": false,
    "modelDownloads": false,
    "maximumRequestBytes": 65536,
    "maximumMessageBytes": 32768,
    "maximumConversationMessages": 20,
    "modelSelection": "per-capability-in-browser-memory",
    "modelResidency": "bounded-idle-timeout",
    "defaultIdleUnloadSeconds": 300,
    "allowedIdleUnloadSeconds": [0, 300, 900, 1800],
    "unloadOnFailure": true,
    "unloadOnNewTask": true,
    "unloadOnModelOrProviderChange": true,
    "unloadOnShutdown": true,
    "maximumResponseBytes": 1048576
  }
}
